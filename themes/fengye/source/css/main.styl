@import 'highlight.styl'

html, body
  width: 100%
  margin: 0px
  padding: 0px
  text-underline-offset: 2px
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
  transition-duration: 0.2s

:root {
  --c-transparent: transparent
  --c-theme-1: #bed5f9
  --c-theme: #4f90e6
  --c-theme-2: #3058b6
  --c-0: #ffffff
  --c-10: #f6f8fa
  --c-20: #f3f4f6
  --c-25: #e5e7eb
  --c-30: #e5e7eb
  --c-40: #d1d5db
  --c-50: #9ca3af
  --c-60: #6b7280
  --c-70: #4b5563
  --c-80: #374151
  --c-90: #1f2937
  --c-100: #111827
  --c-text: #444444
  --c-bg-code: #f6f8fa
  --c-code-line-number: #bbb
  --c-scrollbar: #d9d9d9
  --c-scrollbar-hover: #bbbbbb
  --c-border: #d1d7dd
  --c-sep: #e1e4e8
  --c-sep-2: #d1d4d8
  --c-code-language: #9ca3af
  --h-header: 48px
}

html.dark
  --c-theme-1: #204679
  --c-theme: #5393d2
  --c-theme-2: #415876
  --c-0: #181818
  --c-10: #1f1f1f
  --c-20: #282828
  --c-25: #2e2e2e
  --c-30: #404244
  --c-40: #5e606b
  --c-50: #7d7e80
  --c-60: #909495
  --c-70: #bbbebf
  --c-80: #c9cbcf
  --c-80: #d9d9d9
  --c-90: #e1e4e8
  --c-100: #e7edf2
  --c-text: #eeeeee
  --c-bg-code: #111111
  --c-scrollbar: #333333
  --c-scrollbar-hover: #555555
  --c-border: #31363c
  --c-sep: #3f4339
  --c-sep-2: #818488
  --c-code-language: #8c939f

a
  color: var(--c-theme)
  transition: color 0.1s ease-in-out
  &:hover
    color: var(--c-theme)
    cursor: pointer

[data-i18n-lang][hidden]
  display: none !important

.language-toggle
  min-width: 58px
  height: 34px
  display: inline-flex
  align-items: center
  justify-content: center
  gap: 4px
  border: 1px solid var(--c-border)
  border-radius: 8px
  padding: 0 8px
  color: var(--c-80)
  background: var(--c-0)
  font-weight: 900
  cursor: pointer
  transition: all 0.1s ease-in-out

.language-toggle:hover
  color: var(--c-theme)
  border-color: var(--c-theme)
  background: var(--c-20)

.toc-list
  li
    margin-top: 0.2rem
    margin-bottom: 0.2rem
  ol
    margin-top: 0.2rem

.back-to-top
  -webkit-transform: translateZ(0)
  transition-property: bottom
  transition-duration: 0.2s
  transition-timing-function: ease-in-out
  transition-delay: 0s
  &:hover
    transform: scale(1.15)
    transition-property: transform;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  &.back-to-top-on
    bottom: 30px

@keyframes enter
  0%
    opacity: 0
    transform: translateY(10px)

  to
    opacity: 1
    transform: none

[data-animate]
  --stagger: 0
  --delay: 120ms
  --start: 0ms

@media (prefers-reduced-motion:no-preference)
  [data-animate]
    animation: enter .6s both
    animation-delay: calc(var(--stagger) * var(--delay) + var(--start))

[data-animation-controller=false] [data-animate]
  animation: none;

.post-content
  max-width: 860px
  font-size: 1rem
  line-height: 1.78
  hr.footnotes-sep
    background-color: var(--c-sep)
    margin-bottom: 1.0rem
    margin-right: 50%;
  hr
    background-color: var(--c-sep)
    height: 1px
    margin: 1.5rem 0
  border-bottom: 0
  blockquote
    margin: 1rem 0
    border-left: 3px solid var(--c-theme)
    padding: 0.2rem 0 0.2rem 12px
    background: var(--c-10)
    p
      margin: 0px 6px
      font-style: normal
      color: var(--c-70)
  code
    ::before
      content: ''

.post-page
  padding-bottom: 48px

.post-content.prose
  max-width: 860px

.post-content h1
  margin-top: 2rem
  margin-bottom: 0.9rem
  padding-bottom: 0.35rem
  border-bottom: 1px solid var(--c-sep)
  color: var(--c-100)
  font-size: 1.75rem
  line-height: 1.28
  font-weight: 900

.post-content h2
  margin-top: 1.75rem
  margin-bottom: 0.7rem
  color: var(--c-100)
  font-size: 1.38rem
  line-height: 1.32
  font-weight: 900

.post-content h3
  margin-top: 1.35rem
  margin-bottom: 0.55rem
  color: var(--c-90)
  font-size: 1.12rem
  line-height: 1.4
  font-weight: 850

.post-content p
  margin: 0.78rem 0

.post-content ul,
.post-content ol
  margin: 0.8rem 0 0.8rem 1.25rem
  padding: 0

.post-content li
  margin: 0.24rem 0
  line-height: 1.72

.post-content img
  display: block
  max-width: 100%
  max-height: 560px
  margin: 1.1rem auto
  border-radius: 8px
  border: 1px solid var(--c-sep)
  background: var(--c-10)

.math-display
  overflow: visible
  margin: 1.1rem 0
  padding: 0.8rem 0.5rem
  border: 1px solid var(--c-sep)
  border-radius: 8px
  background: var(--c-10)
  text-align: center

.math-display mjx-container[jax="CHTML"][display="true"]
  margin: 0
  max-width: 100%
  transform-origin: center center

.math-inline mjx-container
  display: inline-block
  vertical-align: -0.15em

.personal-footer
  height: 32px

hr
  border: 0px

::selection
  background-color: var(--c-theme)
  color: var(--c-0)

.prose
  color: var(--c-text)
  h2
    margin-top: 1.0em
    margin-bottom: 0.6em
  p
    margin: 0.8rem 0px
    line-height: 1.5
  li
    margin: 0px
  ul
    margin: 0px
  ol
    margin: 0px
    p
      margin: 0px
  input
    margin: 0px
  code::before
    content: ''
  code::after
    content: ''
  code
    background-color: var(--c-bg-code)
    border-radius: 4px
    padding: 0.2em 0.3em
    font-size: 0.9em
    font-weight: 400
  a
    color: var(--c-theme)
    text-decoration: none
    &:hover
      text-decoration: underline
  blockquote
    ::before
      content: ''
  .footnotes
    font-size: 0.8rem
  .footnote-backref
    text-decoration: none
    border-radius: 4px
    padding: 1px
    &:hover
      text-decoration: underline
      background-color: var(--c-theme)
      color: var(--c-0)
  .fancybox-img
    img
      margin-bottom: 0.5rem
      align: center
      display: block
      margin-left: auto
      margin-right: auto
  .fancybox-title
    font-size: 0.9rem
    text-align: center
    color: #aaa
    margin: 0px 0px
    padding: 0px 0px
    font-style: normal
    width: 100%
    display: block
    // display: none
    
  .fancybox-alt
    font-size: 0.9rem
    text-align: center
    color: #aaa
    margin: 0px 0px
    padding: 0px 0px
    font-style: normal
    width: 100%
    // display: none
    display: block

li.task-list-item
  list-style-type: none

li.task-list-item .task-list-item-checkbox
  margin: 0 0.2em 0.25em -1.6em;

  input:checked
    color: var(--c-theme)
    text-decoration: line-through

.post-excerpt
  pointer-events: none;
  // border-bottom: 1px solid var(--c-sep)
  a
    text-decoration: underline
  //   &:hover
  //     color: var(--c-theme)
  p
    margin: 2px 0px
    padding: 2px 0px

.personal-home
  max-width: 1120px
  margin: 0 auto
  padding: 48px 20px 72px

.personal-hero
  display: grid
  grid-template-columns: 220px minmax(0, 1fr)
  gap: 48px
  align-items: center
  min-height: calc(100vh - var(--h-header) - 140px)
  padding: 12px 0 44px

.personal-hero--no-media
  grid-template-columns: minmax(0, 1fr)
  min-height: auto
  padding-top: 34px

.personal-hero__media
  display: flex
  align-items: center
  justify-content: center

.personal-portrait
  width: 192px
  height: 192px
  border-radius: 8px
  object-fit: cover
  border: 1px solid var(--c-border)
  background: var(--c-10)
  box-shadow: 0 18px 50px rgba(22, 30, 46, 0.10)

.personal-hero__body
  display: flex
  flex-direction: column
  gap: 14px

.personal-kicker
  margin: 0
  color: #0f766e
  font-size: 0.9rem
  font-weight: 800
  letter-spacing: 0
  text-transform: uppercase

.personal-hero h1
  margin: 0
  color: var(--c-100)
  font-size: clamp(2rem, 4.2vw, 3.35rem)
  line-height: 1.08
  font-weight: 900
  letter-spacing: 0

.personal-hero h1 span
  display: block
  margin-top: 8px
  color: var(--c-60)
  font-size: clamp(1.4rem, 3vw, 2rem)
  line-height: 1.1
  font-weight: 800

.personal-affiliation
  margin: 0
  max-width: 760px
  color: var(--c-70)
  font-size: 1.12rem
  font-weight: 700
  line-height: 1.45

.personal-intro
  margin: 0
  max-width: 760px
  color: var(--c-text)
  font-size: 1rem
  line-height: 1.75

.personal-actions
  display: flex
  flex-wrap: wrap
  align-items: center
  gap: 10px
  margin-top: 6px

.personal-button,
.personal-location
  min-height: 40px
  display: inline-flex
  align-items: center
  gap: 8px
  border-radius: 8px
  border: 1px solid var(--c-border)
  padding: 0 14px
  font-weight: 800
  color: var(--c-80)
  background: var(--c-0)

.personal-button:hover
  color: var(--c-theme)
  border-color: var(--c-theme)

.personal-button--primary
  color: white
  border-color: #0f766e
  background: #0f766e

.personal-button--primary:hover
  color: white
  border-color: #115e59
  background: #115e59

.personal-location
  color: var(--c-60)
  background: var(--c-10)

.personal-section
  padding: 44px 0
  border-top: 1px solid var(--c-sep)

.personal-section--compact
  padding: 34px 0

.personal-section__head
  margin-bottom: 22px

.personal-section__head p
  margin: 0 0 6px
  color: #b45309
  font-size: 0.82rem
  font-weight: 900
  text-transform: uppercase
  letter-spacing: 0

.personal-section__head h2
  margin: 0
  color: var(--c-100)
  font-size: 1.8rem
  line-height: 1.2
  font-weight: 900
  letter-spacing: 0

.personal-grid
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 16px

.personal-grid--notes
  grid-template-columns: repeat(2, minmax(0, 1fr))

.personal-card,
.personal-row
  border: 1px solid var(--c-border)
  border-radius: 8px
  background: var(--c-0)
  box-shadow: 0 10px 28px rgba(22, 30, 46, 0.06)

.personal-card
  padding: 20px

.personal-card__label
  margin: 0 0 10px
  color: #0f766e
  font-size: 0.78rem
  font-weight: 900
  text-transform: uppercase

.personal-card h3,
.personal-row h3
  margin: 0
  color: var(--c-100)
  font-size: 1.08rem
  line-height: 1.35
  font-weight: 900

.personal-card__meta
  margin: 8px 0 10px
  color: var(--c-60)
  font-size: 0.92rem
  font-weight: 700

.personal-card p,
.personal-row p
  color: var(--c-text)
  line-height: 1.65

.personal-card p:last-child,
.personal-row p:last-child
  margin-bottom: 0

.personal-list
  display: grid
  gap: 14px

.personal-entry,
.personal-publication
  border: 1px solid var(--c-border)
  border-radius: 8px
  background: var(--c-0)
  box-shadow: 0 10px 28px rgba(22, 30, 46, 0.06)

.personal-entry
  display: grid
  grid-template-columns: 96px minmax(0, 1fr)
  gap: 20px
  align-items: center
  padding: 20px

.personal-entry__logo
  width: 96px
  max-height: 64px
  object-fit: contain

.personal-entry h3,
.personal-publication h3
  margin: 0
  color: var(--c-100)
  font-size: 1.08rem
  line-height: 1.35
  font-weight: 900

.personal-entry p,
.personal-publication p
  color: var(--c-text)
  line-height: 1.65

.personal-entry p:last-child,
.personal-publication p:last-child
  margin-bottom: 0

.personal-publication
  padding: 20px

.personal-publication__authors
  margin: 0 0 10px
  color: var(--c-70)
  font-weight: 700

.personal-row
  display: grid
  grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr)
  gap: 24px
  padding: 20px

.personal-chipset
  display: flex
  flex-wrap: wrap
  gap: 10px

.personal-chipset span
  display: inline-flex
  align-items: center
  min-height: 34px
  border: 1px solid rgba(15, 118, 110, 0.25)
  border-radius: 8px
  padding: 0 12px
  color: #0f766e
  background: rgba(20, 184, 166, 0.08)
  font-weight: 800

.personal-chipset--muted span
  color: var(--c-70)
  border-color: var(--c-border)
  background: var(--c-10)

.personal-note__top
  display: flex
  align-items: baseline
  justify-content: space-between
  gap: 12px

.personal-note__top time
  color: var(--c-60)
  font-size: 0.86rem
  font-weight: 800
  white-space: nowrap

.personal-link
  display: inline-flex
  align-items: center
  gap: 4px
  margin-top: 12px
  font-weight: 900

html.dark
  .personal-kicker,
  .personal-card__label,
  .personal-chipset span
    color: #5eead4
  .personal-button--primary
    color: #062925
    background: #5eead4
    border-color: #5eead4
  .personal-section__head p
    color: #fbbf24

@media (max-width: 760px)
  .personal-home
    padding: 28px 16px 56px

  .personal-hero
    grid-template-columns: 1fr
    gap: 24px
    align-items: start
    min-height: auto
    padding-bottom: 34px

  .personal-hero__media
    justify-content: flex-start

  .personal-portrait
    width: 128px
    height: 128px

  .personal-grid,
  .personal-grid--notes,
  .personal-entry,
  .personal-row
    grid-template-columns: 1fr

  .personal-entry__logo
    width: 116px
    max-height: 72px

  .math-display
    font-size: 0.88rem

  .personal-row
    gap: 10px


figure.highlight
  display: flex
  flex-direction: column
  background-color: var(--c-bg-code)
  border-radius: 10px
  border: 1px solid var(--c-sep)

  .code-language
    font-size: 0.8rem
    color: var(--c-50)
    background-color: var(--c-bg-code)
    display: block
  .copy-icon
    right: 8px
    top: 8px
    width: 30px
    height: 30px
    background-color: var(--c-bg-code)
    border: 1px solid var(--c-border)
    color: var(--c-60)
    position: absolute
    cursor: pointer
    border-radius: 4px
    padding: 4px
    // box-shadow: 0 0px 4px rgba(0, 0, 0, 0.3)
    &:hover
      background-color: var(--c-20)
      transform: scale(1.1)


.post-container
  .footnote-ref
    display: none


.search-overlay
  position: fixed
  top: 0
  left: 0
  bottom: 0
  right: 0
  background-color: rgba(0,0,0,0.3)
  transition: background-color 0.2s ease
  visibility: visible
  padding-right: 6px
  backdrop-filter: blur(8px)
  &.hidden:
    background-color: transparent
    visibility: hidden
    transition: visibility 0s linear 0.2s, background-color 0.2s
    padding-right: 0
    .search-content
      position: relative
      top: 15%
      opacity: 0

.search-content
  position: relative
  top: 18%
  opacity: 1
  background-color: transparent
  z-index: 999
  border-radius: 10px
  margin: 0 2rem
  transition: top 0.2s ease, opacity 0.2s ease
  outline: 0


@media (min-width: 768px) {
  .search-content {
    width: 520px;
    margin: 0 auto;
  }
}

.search-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 10px;
  background-color: var(--bg-content-search);
  padding: 0 8px;
  box-shadow: 0 1px 2px 0 rgba(60, 64, 67, .30), 0 1px 3px 1px rgba(60, 64, 67, .15);
}

.search-input {
  width: 100%;
  border: 0;
  outline: 0;
  background-color: transparent;
  padding: 0 10px;
  font-size: 1.6rem;
  height: 38px;
  line-height: 38px;
  color: var(--color-text-a);
}

.search-result {
  max-height: 350px;
  overflow: auto;
  background-color: var(--bg-content-search);
  border-radius: 10px;
  margin-top: 8px;
}

.search-result ul {
  padding: 10px;
}

.search-result-list li {
  list-style-type: none;
  padding: 10px;
  font-size: 1.6rem;
  border-bottom: 1px dashed var(--color-divider-md-border);
}

.search-result-list li:nth-last-of-type(1) {
  border-bottom: none;
}

.search-result-abstract {
  padding: 10px 10px 0 10px;
  font-size: 1.2rem;
  color: var(--color-text-sub);
  word-break: break-all;
}

.search-keyword {
  color: var(--color-text-md-code);
}

.local-search-empty {
  font-size: 1.6rem;
  color: var(--color-text-a);
}
