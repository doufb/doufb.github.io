<%
  var displayName = theme.profile_name || config.title;
  var displayNameEn = theme.profile_name_en || '';
  var intro = theme.profile_intro || config.description || '';
  var interests = theme.research_interests || [];
  var education = theme.homepage_education || [];
  var research = theme.homepage_research || [];
  var publications = theme.homepage_publications || [];
  var notes = theme.homepage_notes || [];
  function esc(value) {
    return String(value == null ? '' : value).replace(/[&<>"']/g, function (char) {
      return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[char];
    });
  }
  function i18n(value) {
    if (value && typeof value === 'object' && !Array.isArray(value)) {
      return '<span data-i18n-lang="zh">' + esc(value.zh || value.en || '') + '</span>' +
        '<span data-i18n-lang="en">' + esc(value.en || value.zh || '') + '</span>';
    }
    return esc(value || '');
  }
%>

<div class="personal-home text-[var(--c-80)]">
  <section class="personal-hero<% if (!theme.show_profile_image) { %> personal-hero--no-media<% } %>">
    <% if (theme.show_profile_image) { %>
    <div class="personal-hero__media">
      <img class="personal-portrait" src="<%- theme.portrait %>" alt="<%- displayName %>" />
    </div>
    <% } %>

    <div class="personal-hero__body">
      <p class="personal-kicker"><%- i18n(theme.profile_role) %></p>
      <h1><%- displayName %><% if (displayNameEn) { %><span><%- displayNameEn %></span><% } %></h1>
      <p class="personal-affiliation"><%- i18n(theme.profile_affiliation) %></p>
      <p class="personal-intro"><%- i18n(intro) %></p>

      <div class="personal-actions">
        <a href="mailto:<%- theme.email %>" class="personal-button personal-button--primary">
          <iconify-icon icon="mingcute:mail-fill" width="20"></iconify-icon>
          <span>Email</span>
        </a>
        <a href="<%- theme.cv_path_zh || theme.cv_path %>" class="personal-button">
          <iconify-icon icon="mingcute:idcard-fill" width="20"></iconify-icon>
          <span>中文简历</span>
        </a>
        <a href="<%- theme.cv_path_en || theme.cv_path %>" class="personal-button">
          <iconify-icon icon="mingcute:file-certificate-fill" width="20"></iconify-icon>
          <span>English CV</span>
        </a>
        <span class="personal-location">
          <iconify-icon icon="mingcute:location-fill" width="20"></iconify-icon>
          <%- i18n(theme.my_location) %>
        </span>
      </div>
    </div>
  </section>

  <section class="personal-section personal-section--compact" id="focus">
    <div class="personal-section__head">
      <p>Focus</p>
      <h2><span data-i18n-lang="zh">研究兴趣</span><span data-i18n-lang="en">Research Interests</span></h2>
    </div>
    <div class="personal-chipset">
      <% interests.forEach(function (item) { %>
      <span><%- i18n(item) %></span>
      <% }) %>
    </div>
  </section>

  <section class="personal-section" id="education">
    <div class="personal-section__head">
      <p><span data-i18n-lang="zh">教育</span><span data-i18n-lang="en">Education</span></p>
      <h2><span data-i18n-lang="zh">教育经历</span><span data-i18n-lang="en">Education</span></h2>
    </div>
    <div class="personal-list">
      <% education.forEach(function (item) { %>
      <article class="personal-entry">
        <% if (item.logo) { %>
        <img class="personal-entry__logo" src="<%- item.logo %>" alt="USTC logo" />
        <% } %>
        <div>
          <h3><%- i18n(item.title) %></h3>
          <p class="personal-card__meta"><%- i18n(item.meta) %></p>
          <p><%- i18n(item.text) %></p>
        </div>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="personal-section" id="research">
    <div class="personal-section__head">
      <p><span data-i18n-lang="zh">科研</span><span data-i18n-lang="en">Research</span></p>
      <h2><span data-i18n-lang="zh">科研经历</span><span data-i18n-lang="en">Research Experience</span></h2>
    </div>
    <div class="personal-list">
      <% research.forEach(function (item) { %>
      <article class="personal-entry">
        <% if (item.logo) { %>
        <img class="personal-entry__logo" src="<%- item.logo %>" alt="USTC logo" />
        <% } %>
        <div>
          <h3><%- i18n(item.title) %></h3>
          <p class="personal-card__meta"><%- i18n(item.meta) %></p>
          <p><%- i18n(item.text) %></p>
        </div>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="personal-section" id="publications">
    <div class="personal-section__head">
      <p><span data-i18n-lang="zh">论文</span><span data-i18n-lang="en">Publications</span></p>
      <h2><span data-i18n-lang="zh">论文发表</span><span data-i18n-lang="en">Publications</span></h2>
    </div>
    <div class="personal-list">
      <% publications.forEach(function (item) { %>
      <article class="personal-publication">
        <h3><%- i18n(item.title) %></h3>
        <p class="personal-card__meta"><%- i18n(item.meta) %></p>
        <% if (item.authors) { %>
        <p class="personal-publication__authors"><%- i18n(item.authors) %></p>
        <% } %>
        <% if (item.text) { %>
        <p><%- i18n(item.text) %></p>
        <% } %>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="personal-section" id="notes">
    <div class="personal-section__head">
      <p><span data-i18n-lang="zh">笔记</span><span data-i18n-lang="en">Notes</span></p>
      <h2><span data-i18n-lang="zh">阅读笔记</span><span data-i18n-lang="en">Reading Notes</span></h2>
    </div>
    <div class="personal-grid personal-grid--notes">
      <% notes.forEach(function (item) { %>
      <article class="personal-card personal-note">
        <div class="personal-note__top">
          <p class="personal-card__label"><%- i18n(item.label) %></p>
          <time><%- item.date %></time>
        </div>
        <h3><%- i18n(item.title) %></h3>
        <p><%- i18n(item.text) %></p>
        <a href="<%- item.link %>" target="_blank" rel="noopener" class="personal-link">
          <span data-i18n-lang="zh">阅读笔记</span><span data-i18n-lang="en">Read note</span>
          <iconify-icon icon="mingcute:arrow-right-up-fill" width="18"></iconify-icon>
        </a>
      </article>
      <% }) %>
    </div>
  </section>
</div>
